APP_NAME="Islamic Learning"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Comma-separated origins for Flutter web / browser clients (use * for local dev)
CORS_ALLOWED_ORIGINS=*

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Database (SQLite by default; use mysql for production if preferred)
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=islamic_learning_backend
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# Admin panel (seeded via AdminUserSeeder)
ADMIN_NAME="Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
